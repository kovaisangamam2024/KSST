<!DOCTYPE html>
<html>
<head>
<title>KSST Parayanam Allocation</title>

<style>
body{
font-family: Arial;
background:#f6f6f6;
padding:20px;
text-align:center;
}

textarea{
width:300px;
height:150px;
padding:10px;
}

button{
padding:10px 20px;
margin:10px;
font-size:16px;
}

table{
margin:auto;
border-collapse:collapse;
background:white;
}

td,th{
border:1px solid #ccc;
padding:8px 12px;
}
</style>
</head>

<body>

<h2>KSST Parayanam Allocation</h2>

<p>Enter Names (one per line)</p>

<textarea id="names"></textarea>
<br>

<button onclick="allocate()">Generate Allocation</button>

<div id="result"></div>

<script>

function allocate(){

let names = document.getElementById("names").value.trim().split("\n");

let totalSlokas = 108;

let perPerson = Math.floor(totalSlokas / names.length);
let extra = totalSlokas % names.length;

let start = 1;

let html = "<table>";
html += "<tr><th>Name</th><th>Section</th></tr>";

names.forEach((name,i)=>{

let count = perPerson + (i < extra ? 1 : 0);

let end = start + count - 1;

let section = `
Starting Prayer
Mahalakshmi Ashtakam
Poorvanga 1–22
Nyasa
Dhyanam 1–8
Sloka ${start}–${end}
Phalashruti
Ending Prayer
`;

html += `<tr>
<td>${name}</td>
<td>${section}</td>
</tr>`;

start = end + 1;

});

html += "</table>";

document.getElementById("result").innerHTML = html;

}

</script>

</body>
</html>
